import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

df = pd.read_csv("LaserIntensityThreshold.csv")
I = df["I_mA"]
P = df["P_uW"]
threshold = 125
h = I < threshold
v = I >= threshold

m1, b1 = np.polyfit(I[h], P[h], 1)  
m2, b2 = np.polyfit(I[v], P[v], 1)  

print("x1 = ", m1)
print("x2 = ", m2)

plt.figure()
plt.plot(I, P, label='Data')
plt.xlabel("Intensity (mA)")
plt.ylabel("Power (uW)")
plt.title("Laser Intensity Threshold")
plt.grid()
plt.show()